<configuration>
    <appender name="fileAppender" class="ch.qos.logback.core.FileAppender">
        <encoder>
            <pattern>
                %d{HH:mm:ss.SSS} [%thread] %-5level %logger{32} -- %msg %n
            </pattern>
        </encoder>
        <file>
            springboot20.log
        </file>
    </appender>
    <appender name="myRollingAppender" class="ch.qos.logback.core.rolling.RollingFileAppender">
     <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
        <fileNamePattern>springboot20-%d{yy-mm-dd_HH-mm}.%i.log</fileNamePattern>
        <maxFileSize>10MB</maxFileSize>
        <maxHistory>10</maxHistory>
     </rollingPolicy>
     <encoder>
        <pattern>
            %d{HH:mm:ss.SSS} [%thread] %-5level %logger{32} -- %msg %n
        </pattern>
     </encoder>
    </appender>
    <appender name="consoleAppender" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{HH:mm:ss.SSS} [%thread] %-5level %logger{32} -- %msg %n
            </pattern>
        </encoder>
    </appender>
    <root level="DEBUG">
        <appender-ref ref="myRollingAppender"/>
        <appender-ref ref="consoleAppender"/>
    
    </root>
</configuration>